# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace-with-at-least-32-random-characters
OAUTH_TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key
UPLOAD_TOKEN_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=perkley_session

# Neon Postgres
DATABASE_URL=postgresql://user:password@host.neon.tech/perkley?sslmode=require

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/oauth/google/callback

# Instagram OAuth
INSTAGRAM_CLIENT_ID=your-instagram-app-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/auth/oauth/instagram/callback

# Upload storage
# Falls back to local disk (UPLOAD_STORAGE_DIR) when Supabase is not configured.
UPLOAD_STORAGE_DIR=./var/uploads

# Supabase Storage (optional). When SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are
# set, uploads go to the bucket below and asset URLs point directly at Supabase.
# Create a PUBLIC bucket named to match SUPABASE_STORAGE_BUCKET.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=media
# Supabase Auth bridge (Google sign-in). Used as the `apikey` when verifying a
# user's Supabase access token at POST /api/auth/supabase. Prefer the
# publishable (anon) key; falls back to the service-role key above if unset.
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Razorpay (optional — dev mode works without keys)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Background jobs
JOBS_ENABLED=false
JOBS_INTERVAL_MS=300000

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Perkley <hello@perkley.com>"
