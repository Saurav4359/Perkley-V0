# Public — exposed to the browser (NEXT_PUBLIC_ prefix required)
# Used by the Supabase browser/server clients to start Google Sign-In and read
# the Supabase session. The publishable (anon) key is safe to expose; never put
# the service-role key in the web app.
NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Backend URL for Next.js rewrites (server-only on Vercel). Browser calls same-origin /api/*.
BACKEND_API_URL=http://localhost:3001
# Production (Vercel): BACKEND_API_URL=https://perkley-v0.onrender.com
# NEXT_PUBLIC_API_URL is optional when using the /api proxy; keep for server-side fallbacks.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_ENV=development

# Must match the API JWT_SECRET so Next.js Proxy can verify session cookies.
JWT_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=perkley_session

# Sentry (optional in local dev)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development
